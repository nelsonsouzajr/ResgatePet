# Servidor
PORT=3000
NODE_ENV=development

# Banco de Dados PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=resgatepet
DB_USER=postgres
DB_PASSWORD=sua_senha_aqui

# JWT – troque por uma string longa e aleatória em produção
JWT_SECRET=troque_por_um_segredo_longo_e_aleatorio
JWT_EXPIRES_IN=7d

# Upload de arquivos
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5
